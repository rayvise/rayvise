{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Raypaste",
  "version": "0.3.2",
  "identifier": "com.raypaste.raypaste",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Raypaste",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "backgroundColor": "#00000000",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: https:; font-src 'self' data:; connect-src 'self' tauri: ipc: http://ipc.localhost https://openrouter.ai https://api.cerebras.ai"
    },
    "macOSPrivateApi": true
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Raypaste",
    "category": "Productivity",
    "shortDescription": "An app for fast AI completions anywhere on your computer.",
    "longDescription": "An app for fast and customizable AI completions in any input on any application on your computer.",
    "copyright": "Copyright © 2026 Raypaste. All rights reserved.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "exceptionDomain": ""
    }
  }
}
